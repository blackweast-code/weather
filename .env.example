SITE_PUBLIC_URL=https://weather-gamma-umber-42.vercel.app
LOCATION_UPDATE_TOKEN=change-this-long-random-admin-token

# Optional fallback location when no saved location exists.
LOCATION_LABEL=서울 성동구
LOCATION_LATITUDE=37.5636
LOCATION_LONGITUDE=127.0365

# Weather and address providers.
KMA_SERVICE_KEY=your-data-go-kr-kma-vilage-forecast-service-key
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# Server-side KakaoTalk "send to me" for Vercel Cron.
CRON_SECRET=change-this-long-random-cron-secret
KAKAO_REFRESH_TOKEN=your-kakao-refresh-token-with-talk-message-scope
KAKAO_REDIRECT_URI=https://weather-gamma-umber-42.vercel.app/api/kakao/callback
# KAKAO_CLIENT_SECRET=your-kakao-client-secret-if-enabled
# KAKAO_OAUTH_STATE=change-this-random-oauth-state

# Persistent location storage for the 8 AM PlayMCP automation.
# Use either the Vercel KV names or the Upstash Redis names.
KV_REST_API_URL=https://your-kv-endpoint.upstash.io
KV_REST_API_TOKEN=your-kv-rest-token
# UPSTASH_REDIS_REST_URL=https://your-redis-endpoint.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
